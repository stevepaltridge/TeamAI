{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "TeamAI: Auto-Pull Latest",
            "type": "shell",
            "command": "git",
            "args": ["pull", "--ff-only", "origin", "main"],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            },
            "runOptions": {
                "runOn": "folderOpen"
            },
            "problemMatcher": [],
            "group": "none"
        },
        {
            "label": "TeamAI: Test API Connection",
            "type": "shell",
            "command": "node",
            "args": ["scripts/ice-api.js", "folders"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "TeamAI: Rebuild Knowledge Base",
            "type": "shell",
            "command": "node",
            "args": ["scripts/build-knowledge-base-v2.js"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "TeamAI: Freshness Check",
            "type": "shell",
            "command": "node",
            "args": ["scripts/freshness-check.js"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
