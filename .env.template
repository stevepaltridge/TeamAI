# ICE / Encompass Credentials
# Copy this file to .env and fill in your values.
# .env is gitignored — your credentials stay local.

# Encompass instance login
ICE_INSTANCE_ID=your_instance_id
ICE_USERNAME=your_username
ICE_PASSWORD=your_password

# OAuth2 API credentials (from Developer Connect)
ICE_CLIENT_ID=your_client_id
ICE_CLIENT_SECRET=your_client_secret
